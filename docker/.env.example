# Example environment for the policast Compose stack.
# Copy to `.env` at the repo root and adjust as needed:
#
#   cp docker/.env.example .env

# HMAC signing secret shared between the sidecar and clients.
# Required. Any non-empty string works for local dev.
POLICAST_UC_SECRET=policast-uc-demo-secret

# Host port the sidecar is published on.
POLICAST_UC_PORT=8765

# Endpoint the datafusion-demo service POSTs ResolveRequests to.
# Inside the Compose network use the service name ("sidecar").
POLICAST_UC_ENDPOINT=http://sidecar:8765

# Principal used by the demo. Swap to explore different enforcement:
#   admin                         -> all rows (minus legal-hold), no column masks
#   physician + name="Dr. Smith"  -> row-filtered to Dr. Smith's patients,
#                                    SSN/diagnosis unmasked
#   analyst   + region=us-east    -> row-filtered to us-east patients,
#                                    SSN + diagnosis masked as `***`
POLICAST_PRINCIPAL_ID=alice@hospital.com
POLICAST_PRINCIPAL_ROLE=analyst
POLICAST_PRINCIPAL_REGION=us-east
POLICAST_PRINCIPAL_NAME=

# Fully-qualified table the demo resolves against UC.
POLICAST_TABLE=hospital.clinical.patients

# Short name registered inside the DataFusion SessionContext and used in
# SQL. Defaults to the last dotted segment of POLICAST_TABLE if unset.
# The Cedar column-mask policies reference this short name via
# `resource.table_name == "patients"`.
POLICAST_GOVERNED_NAME=patients

# Optional: Spark demo (profile `spark`).
# Spark 4.x is Scala 2.13-only and runs on Java 17 (both baked into the image).
# Override the pinned versions if needed.
SPARK_VERSION=4.1.2
SBT_VERSION=1.12.4
# spark-submit log verbosity for the demo output (WARN keeps it readable).
POLICAST_SPARK_LOG_LEVEL=WARN
# In-container paths to the pre-expanded manifest + sample data baked into the
# image. Spark enforces the already-expanded form (concrete table/column
# targets), not the tag-templated `just compile` output. Override only to point
# at a different already-expanded manifest.
POLICAST_MANIFEST_PATH=/opt/policast/examples/policies/manifest.json
POLICAST_DATA_PATH=/opt/policast/examples/data/patients.csv
# Optional corporate Maven mirror used at sbt build time (see
# policast-spark/AGENTS.md). Empty falls back to the public OSS resolvers.
MAVEN_PROXY_URL=

# Optional: Unity Catalog OSS image + port (profiles: uc-oss, uc-full).
# uc-full pins newfrontdocker/unitycatalog:v0.4.1 by default.
UNITYCATALOG_IMAGE=newfrontdocker/unitycatalog:v0.4.1
UNITYCATALOG_PORT=8081

# Optional: full UC-backed profile (`--profile uc-full`) extras.
# The uc-full sidecar publishes on this host port.
POLICAST_UC_FULL_PORT=8766
# Refresh cadence for sidecar --backend uc-bootstrap in uc-full mode.
POLICAST_UC_REFRESH_SECS=30

# MinIO credentials / ports / region for uc-full profile.
MINIO_IMAGE=minio/minio:latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
